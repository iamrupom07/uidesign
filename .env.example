# Monorepo Environment Variables Example

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/my_database?schema=public"

# Auth
BETTER_AUTH_SECRET="super-secret-better-auth-key-min-32-chars-long"
BETTER_AUTH_URL="http://localhost:5000"

# Web App & API URLs
NEXT_PUBLIC_API_URL="http://localhost:5000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
CLIENT_URL="http://localhost:3000"

# Admin Seeder Initial Credentials
ADMIN_NAME="System Administrator"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="Admin123!"

# Nodemailer SMTP
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="smtp_user"
SMTP_PASS="smtp_pass"
EMAIL_FROM="noreply@macprotec.com"
